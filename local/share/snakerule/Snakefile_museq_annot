rule annovar:
    input: ADIR+"/extracted_p2_{sample}.txt.gz", ADIR+"/extracted_p3_{sample}.txt.gz"
    output: "{sample}.hg38_multianno.txt"
    log: log="{sample}_annovar.log"
    shell: 
        """ 
            zcat {input} | bawk '{{print $1,$2,$2, $3, $4}}' > {output}.bed
            table_annovar.pl {output}.bed /mnt/trcanmed/snaketree/task/variant_annotations/dataset/annovar/hg38/humandb/ -otherinfo -buildver hg38 -out {wildcards.sample}  -remove -protocol refGene,avsnp150,cosmic87_coding -operation g,f,f -nastring . -polish &> {log.log}
            rm {output}.bed
        """

# manual check no ;, we keep entire row to have cosmic
rule nonsyn_orstop:
    input: "{sample}.hg38_multianno.txt"
    output: "{sample}_nonsynstop.txt"
    shell: 
        """
            bawk '$6=="exonic" && ($9=="nonsynonymous SNV" || $9=="stopgain")' {input} > {output}
        """

rule intogen:   
    input: muts="{sample}_nonsynstop.txt", drivers=INTOGEN
    output: "{sample}_relevant.txt"
    shell:
        """
            join -t $'\\t' -1 1 -2 7 <(sed 1d {input.drivers} | sort -k1,1) <(sort -k7,7 {input.muts}) > {output}
        """

rule all_relevant:
   input: expand('{sample}_relevant.txt', sample=SAMPLES)


rule nonsyn_all:
    input: expand('{sample}_nonsynstop.txt', sample=SAMPLES)
    output: tsv="nonsyn_stop_all.tsv", genes="nonsyn_stop_allgenes.tsv"
    shell:
        """
            cat CRC0282.hg38_multianno.txt |  bawk 'NR==1{{print "sample",$0}}' > {output.tsv}
            for f in {input}; do cat $f | bawk -v n="$f" 'NR!=1{{print n, $0}}'; done | sed 's/_nonsynstop.txt//1'  >> {output.tsv}
            sed 1d {output.tsv} | cut -f 8 | sort | uniq > {output.genes}
        """

