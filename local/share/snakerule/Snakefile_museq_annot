include: "conf.sk"

rule dnds:
    input: mut=ADIR+"/extracted_p2_{sample}.txt.gz", mut2=ADIR+"/extracted_p3_{sample}.txt.gz", rda=DNDSCV_RDA
    output: "{sample}_dnds.tsv", "{sample}_dnds.Rdata"
    log: "{sample}_dnds.log"
    params:  tool=BIN_DIR+"/dnds"
    shell:
        """
            zcat {input.mut} {input.mut2} |  bawk '{{print "all","chr"$1,$2,$3,$4}}' > {output[0]}.tmp
            {params.tool} {output[0]}.tmp {output} {input.rda} &> {log}
            rm {output[0]}.tmp
        """ 

rule all_dnds:
   input: expand('{sample}_dnds.tsv', sample=SAMPLES)

