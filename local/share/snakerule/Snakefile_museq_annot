rule get_GO_global:
    input: genes='nonsyn_stop_allgenes.tsv', universe='universe'
    output:  enrich="GO_global.tsv"
    script: SRC_DIR+'/GO_enrich.R'

rule goenrich_tab:
    input: expand('{sample}_enriched2.GO', sample=SAMPLES)
    output: 'allGOenrich.tsv'
    shell: """
            head -n1 {input[0]} | bawk '{{print  "sample",$1,$2,$3,$4,$5,$12,$14}}' > {output}
            for f in {input}; do bawk -v sample="$f" 'NR!=1 {{print sample,$1,$2,$3,$4,$5,$12,$14}}' $f; done | sed 's/_enriched2\.GO//1' >> {output}
           """

rule gorelevant_tab:
    input: expand('{sample}.relevantGO2.tsv', sample=SAMPLES)
    output: 'allGOrelevant.tsv'
    shell: """
            head -n1 {input[0]} | bawk '{{print  "sample",$5,$1,$6}}' > {output}
            for f in {input}; do bawk -v sample="$f" 'NR!=1{{print sample,$5,$1,$6}}' $f | sort | uniq; done | sed 's/\.relevantGO2\.tsv//1' >> {output}

           """

rule xls:
    input: 'allGOrelevant.tsv', 'allGOenrich.tsv'
    output: 'GO_annot.xlsx'
    shell:
        """
            tsv_to_xls -s GOenrich,GOtraversal -i {input[1]},{input[0]} -o {output}
        """


